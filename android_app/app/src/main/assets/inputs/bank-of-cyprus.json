{
  "id": "bank-of-cyprus",
  "displayName": "Bank of Cyprus",
  "enabled": true,
  "priority": 30,
  "match": {
    "senders": [
      "boc message"
    ]
  },
  "transforms": [
    "foldGreek",
    "normalizeAmount"
  ],
  "rules": [
    {
      "name": "card-use",
      "type": "regex",
      "pattern": "Η\\s+ΚΑΡΤΑ\\s+ΣΑΣ\\s+[A-Z]+\\*?(?<card>\\d{4})\\s+ΕΧΕΙ\\s+ΧΡΗΣΙΜΟΠΟΙΗΘΕΙ\\s+ΣΤΟ\\s+(?<merchant>[\\s\\S]+?)\\s+ΣΤΙΣ\\s+\\d{1,2}/\\d{1,2}/\\d{4},\\s+\\d{1,2}:\\d{2}\\s+ΓΙΑ\\s+ΤΟ\\s+ΕΝΔΕΙΚΤΙΚΟ\\s+ΠΟΣΟ\\s+€\\s*(?<amount>(?:[0-9]{1,3}(?:[.,][0-9]{3})*[.,][0-9]{2}|[0-9]+(?:[.,][0-9]{2})?))\\.?",
      "flags": [
        "caseInsensitive",
        "unicodeCase"
      ],
      "output": {
        "currency": "EUR",
        "paymentMethod": "Credit Card",
        "category": "@keyword"
      }
    },
    {
      "name": "account-debit",
      "type": "regex",
      "pattern": "Ο\\s+ΛΟΓ[\\s\\S]*?\\d{3,}[\\s\\S]*?ΧΡΕΩΘΗΚΕ[\\s\\S]*?ΠΟΣΟ\\s+(?:ΤΩΝ\\s+)?(?<currency>EUR|USD|GBP)\\s*(?<amount>(?:[0-9]{1,3}(?:[.,][0-9]{3})*[.,][0-9]{2}|[0-9]+(?:[.,][0-9]{2})?))[\\s\\S]*?ΠΕΡΙΓΡΑΦΗ\\s*:\\s*(?<merchant>.+?)\\s*$",
      "flags": [
        "caseInsensitive",
        "unicodeCase",
        "multiline"
      ],
      "output": {
        "paymentMethod": "Electronic Transfer",
        "category": "@accountDebitKeyword"
      }
    },
    {
      "name": "account-credit",
      "type": "regex",
      "pattern": "Ο\\s+ΛΟΓ[\\s\\S]*?\\d{3,}[\\s\\S]*?ΠΙΣΤΩΘΗΚΕ[\\s\\S]*?ΠΟΣΟ\\s+(?:ΤΩΝ\\s+)?(?<currency>EUR|USD|GBP)\\s*(?<amount>(?:[0-9]{1,3}(?:[.,][0-9]{3})*[.,][0-9]{2}|[0-9]+(?:[.,][0-9]{2})?))[\\s\\S]*?ΠΕΡΙΓΡΑΦΗ\\s*:[\\s\\S]*?\\bBY\\s+(?<merchant>[^>]+)(?:>[^>]+>(?<note>.+?))?\\s*$",
      "flags": [
        "caseInsensitive",
        "unicodeCase",
        "multiline"
      ],
      "output": {
        "type": "INCOME",
        "paymentMethod": "Electronic Transfer",
        "category": "Income"
      }
    },
    {
      "name": "incoming-credit",
      "type": "regex",
      "pattern": "\\bcredited\\s+with\\s+the\\s+amount\\s+of\\s+(?<currency>EUR|USD|GBP)\\s*(?<amount>(?:[0-9]{1,3}(?:[.,][0-9]{3})*[.,][0-9]{2}|[0-9]+(?:[.,][0-9]{2})?))[\\s\\S]*?\\bFrom:\\s*(?<merchant>.+?)(?:\\s+Details:\\s*(?<note>.+?))?\\s*$",
      "flags": [
        "caseInsensitive"
      ],
      "output": {
        "type": "INCOME",
        "paymentMethod": "Electronic Transfer",
        "category": "Income"
      }
    },
    {
      "name": "unmatched-bank-amount",
      "type": "amountFallback",
      "merchantSource": "empty",
      "noteSource": "body",
      "output": {
        "paymentMethod": "Electronic Transfer",
        "category": "@keyword"
      }
    }
  ],
  "tests": [
    {
      "name": "card purchase",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "Η ΚΑΡΤΑ ΣΑΣ VISA*1234 ΕΧΕΙ ΧΡΗΣΙΜΟΠΟΙΗΘΕΙ ΣΤΟ SAMPLE SUPERMARKET ΣΤΙΣ 26/05/2026, 20:17 ΓΙΑ ΤΟ ΕΝΔΕΙΚΤΙΚΟ ΠΟΣΟ €15,30.",
      "expect": {
        "amount": "15.30",
        "currency": "EUR",
        "merchant": "SAMPLE SUPERMARKET",
        "category": "Groceries",
        "paymentMethod": "Credit Card"
      }
    },
    {
      "name": "account debit fee",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "Ο ΛΟΓ/ΣΜΟΣ XXXX000000 (ΤΡΕΧΟΥΜΕΝΟΣ) ΧΡΕΩΘΗΚΕ ΜΕ ΤΟ ΠΟΣΟ ΤΩΝ EUR 7,50 ΣΤΙΣ 26/05/2026 20:17. ΠΕΡΙΓΡΑΦΗ: ΠΡΟΜΗΘΕΙΑ",
      "expect": {
        "amount": "7.50",
        "currency": "EUR",
        "merchant": "ΠΡΟΜΗΘΕΙΑ",
        "category": "Bank fees",
        "paymentMethod": "Electronic Transfer"
      }
    },
    {
      "name": "latin-lookalike card purchase",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "H KAPTA ΣAΣ MCARD6004 EXEI XPHΣIMOΠOIHΘEI ΣTO SAMPLE MERCHANT CY ΣTIΣ 12/03/2026, 14:06 ΓIA TO ENΔEIKTIKO ΠOΣO €44,09.",
      "expect": {
        "amount": "44.09",
        "currency": "EUR",
        "merchant": "SAMPLE MERCHANT CY",
        "paymentMethod": "Credit Card"
      }
    },
    {
      "name": "payment order debit",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "O ΛOΓ/ΣMOΣ XXXX000000 (TPEXOYMENOΣ) XPEΩΘHKE ME TO ΠOΣO TΩN EUR 253,94 ΣTIΣ 10/03/2026 01:50. ΠEPIΓPAΦH: ENTOΛH ΠΛHPΩMHΣ DEBIT-SEPA DD SAMPLE BILL 00000000     REF REF0000000000000",
      "expect": {
        "amount": "253.94",
        "currency": "EUR",
        "merchant": "ENTOΛH ΠΛHPΩMHΣ DEBIT-SEPA DD SAMPLE BILL 00000000 REF REF0000000000000",
        "paymentMethod": "Electronic Transfer"
      }
    },
    {
      "name": "account credit Greek",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "O ΛOΓ/ΣMOΣ XXXX000000 (TPEXOYMENOΣ) ΠIΣTΩΘHKE ME TO ΠOΣO TΩN EUR 1.234,56 ΣTIΣ 30/01/2024 16:39. ΠEPIΓPAΦH: EIΣEPXOMENO EMBAΣMA INWARD CY000000000000 BY SAMPLE SENDER>FT00000000>SAMPLE CREDIT DESCRIPTION",
      "expect": {
        "amount": "1234.56",
        "currency": "EUR",
        "merchant": "SAMPLE SENDER",
        "category": "Income",
        "paymentMethod": "Electronic Transfer",
        "type": "INCOME",
        "note": "SAMPLE CREDIT DESCRIPTION"
      }
    },
    {
      "name": "incoming credit",
      "package": "com.textra",
      "app": "Textra",
      "title": "BOC Message",
      "body": "The a/c XXXX000000 (CURRENT) was credited with the amount of EUR 300,00 on 23/05/26 12:55 From: SAMPLE PAYER Details: SAMPLE NOTE",
      "expect": {
        "amount": "300.00",
        "currency": "EUR",
        "merchant": "SAMPLE PAYER",
        "category": "Income",
        "paymentMethod": "Electronic Transfer",
        "type": "INCOME",
        "note": "SAMPLE NOTE"
      }
    }
  ]
}
