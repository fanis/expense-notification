{
  "id": "eurobank",
  "displayName": "Eurobank Cyprus",
  "enabled": true,
  "priority": 40,
  "match": {
    "senders": [
      "eurobank",
      "eurobankcy"
    ]
  },
  "transforms": [
    "foldGreek",
    "normalizeAmount"
  ],
  "rules": [
    {
      "name": "card-approved",
      "type": "regex",
      "pattern": "Η\\s+ΚΑΡΤΑ\\s+\\*?(?<card>\\d{4})\\s+ΕΓΚΡΙΘΗΚΕ\\s+ΓΙΑ\\s+(?<merchant>.+?)\\s+€\\s*(?<amount>[0-9]+(?:[.,][0-9]{2})?)\\s*(?:@\\d{1,2}:\\d{2})?\\s*$",
      "flags": [
        "unicodeCase"
      ],
      "output": {
        "currency": "EUR",
        "paymentMethod": "Credit Card",
        "category": "@keyword"
      }
    },
    {
      "name": "incoming-credit",
      "type": "regex",
      "pattern": "ΛΟΓΑΡΙΑΣΜΟΣ[\\s\\S]*?ΠΙΣΤΩΘΕΙ[\\s\\S]*?ΠΟΣΟ\\s+ΤΩΝ\\s+(?<amount>(?:[0-9]{1,3}(?:[.,][0-9]{3})*[.,][0-9]{2}|[0-9]+(?:[.,][0-9]{2})?))\\s*(?<currency>EUR|USD|GBP)",
      "flags": [
        "caseInsensitive",
        "unicodeCase"
      ],
      "output": {
        "type": "INCOME",
        "paymentMethod": "Electronic Transfer",
        "category": "Income"
      }
    },
    {
      "name": "unmatched-bank-amount",
      "type": "amountFallback",
      "merchantSource": "empty",
      "noteSource": "body",
      "output": {
        "paymentMethod": "Electronic Transfer",
        "category": "@keyword"
      }
    }
  ],
  "tests": [
    {
      "name": "card approved",
      "package": "com.textra",
      "app": "Textra",
      "title": "Eurobank",
      "body": "Η ΚΑΡΤΑ *0000 ΕΓΚΡΙΘΗΚΕ ΓΙΑ SAMPLE MERCHANT €35,16 @18:50",
      "expect": {
        "amount": "35.16",
        "currency": "EUR",
        "merchant": "SAMPLE MERCHANT",
        "paymentMethod": "Credit Card"
      }
    },
    {
      "name": "incoming credit with grouped amount",
      "package": "com.textra",
      "app": "Textra",
      "title": "EurobankCY",
      "body": "Ο ΛΟΓΑΡΙΑΣΜΟΣ ΣΑΣ 000-00-******-00 ΕΧΕΙ ΠΙΣΤΩΘΕΙ ΜΕ ΤΟ ΠΟΣΟ ΤΩΝ                1.234,56 EUR ΣΤΙΣ 27/11/2025,08:44",
      "expect": {
        "amount": "1234.56",
        "currency": "EUR",
        "category": "Income",
        "paymentMethod": "Electronic Transfer",
        "type": "INCOME"
      }
    }
  ]
}
